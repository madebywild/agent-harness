flowchart TD
  I["load config"] --> V1["validate schema"]
  V1 --> N["normalize + default values"]
  N --> RS["resolve source references"]
  RS --> SP["build specimens + hash"]
  SP --> PR["run processors by target vendor"]
  PR --> FR["collect fragments + diagnostics"]
  FR --> MG["merge by artifact + strategy"]
  MG --> LK["compute lock model"]
  LK --> PL["plan result"]

  PL --> AP{"apply?"}
  AP -->|no| OUT1["return plan only"]
  AP -->|yes| WR["write artifacts + lock"]
  WR --> PRU{"--prune?"}
  PRU -->|yes| DEL["delete stale managed outputs/sections"]
  PRU -->|no| OUT2["done"]
  DEL --> OUT2
