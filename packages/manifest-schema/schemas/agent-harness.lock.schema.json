{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.dev/schemas/agent-harness.lock.schema.v1.json",
  "title": "Agent Harness Lockfile v1 (Draft Skeleton)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "lockfileVersion",
    "generatedAt",
    "generatedBy",
    "configFingerprint",
    "stateFingerprint",
    "vendors",
    "resources",
    "bindings",
    "artifacts",
    "diagnostics"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://agent-harness.dev/schemas/agent-harness.lock.schema.v1.json"
    },
    "lockfileVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "$ref": "#/$defs/generatedBy"
    },
    "configFingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "stateFingerprint": {
      "$ref": "#/$defs/sha256",
      "description": "sha256 of canonicalized lock payload with stateFingerprint omitted"
    },
    "vendors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/vendorRecord"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resourceRecord"
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bindingRecord"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRecord"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "idSegment": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "vendorId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "relativePosixPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//).+"
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolkitVersion", "nodeVersion", "platform"],
      "properties": {
        "toolkitVersion": {
          "type": "string",
          "minLength": 1
        },
        "nodeVersion": {
          "type": "string",
          "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "platform": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "vendorRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendorId", "adapterVersion", "processorIds"],
      "properties": {
        "vendorId": {
          "$ref": "#/$defs/vendorId"
        },
        "adapterVersion": {
          "type": "string",
          "minLength": 1
        },
        "processorIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "resourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status", "source", "specimen"],
      "properties": {
        "id": {
          "$ref": "#/$defs/idSegment"
        },
        "type": {
          "enum": [
            "skill",
            "mcp_server",
            "system_prompt",
            "lifecycle_hook",
            "environment_config",
            "subagent"
          ]
        },
        "status": {
          "enum": ["resolved", "cached", "failed"]
        },
        "source": {
          "$ref": "#/$defs/sourceRecord"
        },
        "specimen": {
          "$ref": "#/$defs/specimenRecord"
        }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "retrieval"],
      "properties": {
        "kind": {
          "enum": [
            "inline_text",
            "local_file",
            "local_dir",
            "git_repo",
            "http_file",
            "http_archive",
            "skills_package",
            "executable_source"
          ]
        },
        "retrieval": {
          "enum": ["local", "git", "http", "executable", "cache"]
        },
        "retrievedAt": {
          "type": "string",
          "format": "date-time"
        },
        "resolvedRef": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relativePosixPath"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        },
        "subpath": {
          "$ref": "#/$defs/relativePosixPath"
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "executor": {
          "type": "string",
          "enum": ["npx"]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idSegment"
          },
          "uniqueItems": true
        },
        "normalizedCommand": {
          "type": "string",
          "minLength": 1
        },
        "commandFingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "runtime": {
          "type": "string",
          "enum": ["node", "python", "binary"]
        },
        "executable": {
          "type": "string",
          "enum": ["npx", "uvx", "pipx"]
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "mode"],
          "properties": {
            "path": {
              "$ref": "#/$defs/relativePosixPath"
            },
            "mode": {
              "enum": ["copy"]
            }
          }
        },
        "nonInteractive": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "skills_package"
              }
            }
          },
          "then": {
            "required": [
              "executor",
              "locator",
              "normalizedCommand",
              "commandFingerprint"
            ],
            "properties": {
              "retrieval": {
                "const": "executable"
              }
            },
            "not": {
              "required": ["ref"]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "executable_source"
              }
            }
          },
          "then": {
            "required": [
              "runtime",
              "executable",
              "package",
              "args",
              "capture",
              "nonInteractive",
              "commandFingerprint"
            ],
            "properties": {
              "retrieval": {
                "const": "executable"
              },
              "nonInteractive": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": ["git_repo", "http_file", "http_archive"]
              }
            }
          },
          "then": {
            "required": ["url"]
          }
        }
      ]
    },
    "specimenRecord": {
      "type": "object",
      "required": ["kind", "digestSha256"],
      "properties": {
        "kind": {
          "enum": [
            "SystemPromptSpecimen",
            "SkillPackageSpecimen",
            "McpServerSpecimen",
            "LifecycleHookSpecimen",
            "EnvironmentConfigSpecimen",
            "SubagentSpecimen"
          ]
        },
        "digestSha256": {
          "$ref": "#/$defs/sha256"
        },
        "contentSha256": {
          "$ref": "#/$defs/sha256"
        },
        "format": {
          "enum": ["markdown", "text"]
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileDigest"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "SkillPackageSpecimen"
              }
            }
          },
          "then": {
            "required": ["files"]
          }
        }
      ],
      "additionalProperties": true
    },
    "fileDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePosixPath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "bindingRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingId",
        "resourceId",
        "vendor",
        "processorId",
        "status",
        "fragmentIds"
      ],
      "properties": {
        "bindingId": {
          "type": "string",
          "pattern": "^[a-f0-9]{24}$"
        },
        "resourceId": {
          "$ref": "#/$defs/idSegment"
        },
        "vendor": {
          "$ref": "#/$defs/vendorId"
        },
        "processorId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["applied", "unsupported", "skipped", "failed"]
        },
        "fragmentIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-f0-9]{24}$"
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "applied"
              }
            }
          },
          "then": {
            "properties": {
              "fragmentIds": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "fragmentIds": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "artifactRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "path",
        "mergeStrategy",
        "contentSha256",
        "contributors"
      ],
      "properties": {
        "artifactId": {
          "$ref": "#/$defs/relativePosixPath"
        },
        "path": {
          "$ref": "#/$defs/relativePosixPath"
        },
        "mergeStrategy": {
          "enum": [
            "single_owner_replace",
            "ordered_concat",
            "json_object_merge",
            "managed_sections"
          ]
        },
        "contentSha256": {
          "$ref": "#/$defs/sha256"
        },
        "contributors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contributorRecord"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mergeStrategy": {
                "const": "managed_sections"
              }
            }
          },
          "then": {
            "properties": {
              "contributors": {
                "items": {
                  "$ref": "#/$defs/managedSectionContributorRecord"
                }
              }
            }
          }
        }
      ]
    },
    "contributorRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingId",
        "fragmentId",
        "fragmentKey",
        "ownerKey",
        "resourceId",
        "specimenDigestSha256"
      ],
      "properties": {
        "bindingId": {
          "type": "string",
          "pattern": "^[a-f0-9]{24}$"
        },
        "fragmentId": {
          "type": "string",
          "pattern": "^[a-f0-9]{24}$"
        },
        "fragmentKey": {
          "$ref": "#/$defs/idSegment"
        },
        "ownerKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+::[A-Za-z0-9._-]+$"
        },
        "sectionKey": {
          "type": "string",
          "pattern": "^[a-f0-9]{16}$"
        },
        "resourceId": {
          "$ref": "#/$defs/idSegment"
        },
        "specimenDigestSha256": {
          "$ref": "#/$defs/sha256"
        },
        "byteStart": {
          "type": "integer",
          "minimum": 0
        },
        "byteEnd": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["byteStart"]
          },
          "then": {
            "required": ["byteEnd"]
          }
        },
        {
          "if": {
            "required": ["byteEnd"]
          },
          "then": {
            "required": ["byteStart"]
          }
        }
      ]
    },
    "managedSectionContributorRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/contributorRecord"
        },
        {
          "type": "object",
          "required": ["sectionKey"]
        }
      ]
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": "string"
        },
        "resourceId": {
          "$ref": "#/$defs/idSegment"
        },
        "bindingId": {
          "type": "string",
          "pattern": "^[a-f0-9]{24}$"
        },
        "vendor": {
          "$ref": "#/$defs/vendorId"
        }
      }
    }
  }
}
