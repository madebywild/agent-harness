{
  "name": "@madebywild/agent-harness-framework",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "restricted"
  },
  "dependencies": {
    "@madebywild/agent-harness-manifest": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "testcontainers": "^11.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build",
    "lint": "biome lint .",
    "lint:write": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "pnpm exec tsx --test test/*.test.ts",
    "test:e2e:containers": "pnpm exec tsx --test test/e2e/**/*.e2e.test.ts",
    "typecheck": "pnpm exec tsc -b --pretty false"
  }
}
