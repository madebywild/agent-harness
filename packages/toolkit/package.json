{
  "name": "@madebywild/agent-harness-framework",
  "version": "1.6.1",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agent",
    "agents",
    "llm",
    "claude",
    "copilot",
    "codex",
    "mcp",
    "harness",
    "cli",
    "workflow",
    "prompt-management"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/madebywild/agent-harness.git",
    "directory": "packages/toolkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inkjs/ui": "^2.0.0",
    "@madebywild/agent-harness-manifest": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "testcontainers": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build",
    "lint": "biome lint .",
    "lint:write": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "pnpm exec tsx --test test/*.test.ts test/*.test.tsx",
    "test:e2e:containers": "pnpm exec tsx --test test/e2e/**/*.e2e.test.ts",
    "typecheck": "pnpm exec tsc -b --pretty false",
    "preview": "pnpm run build && node dist/cli.js"
  }
}
