{
  "name": "agent-harness",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-harness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@agent-harness/manifest-schema": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rm -rf dist",
    "lint": "echo \"No lint task configured\"",
    "test": "pnpm exec tsx --test test/**/*.test.ts",
    "typecheck": "pnpm exec tsc -b --pretty false"
  }
}
