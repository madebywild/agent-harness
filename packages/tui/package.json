{
  "name": "@madebywild/agent-harness-tui",
  "version": "1.5.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agent",
    "tui",
    "ink",
    "terminal",
    "cli",
    "components",
    "storybook"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "storybook": "^10.3.3",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "@storybook/addon-docs": "^10.3.3"
  },
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build",
    "lint": "biome lint .",
    "lint:write": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "echo \"No tests in tui\"",
    "typecheck": "pnpm exec tsc -b --pretty false",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  }
}
