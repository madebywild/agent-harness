{
  "name": "agent-harness-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Agent Harness monorepo",
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm exec turbo run build",
    "clean": "pnpm exec turbo run clean",
    "lint": "biome lint .",
    "lint:write": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "pnpm exec turbo run test",
    "test:e2e:containers": "pnpm --filter @madebywild/agent-harness-framework test:e2e:containers",
    "typecheck": "pnpm exec turbo run typecheck",
    "release:guard": "node scripts/release/release-guard.mjs prepublish",
    "release:verify-published": "node scripts/release/release-guard.mjs verify-published",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "lefthook": "^1.11.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}
